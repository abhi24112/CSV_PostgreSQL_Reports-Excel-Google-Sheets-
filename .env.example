# ---- Postgres ----
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=retail
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Used by database/db_initializer.py (connects to a maintenance DB to create DB_DATABASE)
MAINTENENCE_DB=postgres

# ---- Logging ----
# Logs are written to logs/LOG_FILE
LOG_LEVEL=INFO
LOG_FILE=app.log

# ---- Google Sheets (optional) ----
# Share these Google Sheets with your service account email (client_email in JSON)
# Then set the IDs below.
YEARLY_SHEET_ID=CHANGE_ME
MONTHLY_SHEET_ID=CHANGE_ME
QUARTERLY_SHEET_ID=CHANGE_ME
